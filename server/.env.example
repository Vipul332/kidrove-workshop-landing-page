# ── MongoDB ──────────────────────────────────────────────────────────────────
# Local development: mongodb://127.0.0.1:27017/workshop
# MongoDB Atlas:     mongodb+srv://<user>:<password>@cluster.mongodb.net/workshop
MONGODB_URI=mongodb://127.0.0.1:27017/workshop

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173
